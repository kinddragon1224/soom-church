generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApplicationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum MembershipRole {
  OWNER
  ADMIN
  PASTOR
  LEADER
  VIEWER
}

enum Plan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrganizationUnitType {
  CONGREGATION
  DISTRICT
  GROUP
  DEPARTMENT
  MINISTRY
  FELLOWSHIP
  WORSHIP_COMMUNITY
  SPECIAL_COMMUNITY
  FAMILY_UNIT
  CUSTOM
}

enum MemberOrgRole {
  MEMBER
  LEAD
  ASSISTANT_LEAD
  PASTOR
  STAFF
  VOLUNTEER
  TEACHER
  CUSTOM
}

enum RelationshipType {
  SPOUSE
  PARENT
  CHILD
  SIBLING
  GRANDPARENT
  GRANDCHILD
  GUARDIAN
  RELATIVE
  CAREGIVER
  CUSTOM
}

enum CareCategory {
  VISIT
  ATTENDANCE
  COUNSEL
  HEALTH
  FINANCE
  JOB
  MARRIAGE
  DIVORCE
  FUNERAL
  FAMILY
  MINISTRY
  NOTE
  CUSTOM
}

enum LifeStatusType {
  HEALTH
  FINANCE
  JOB
  MARRIAGE
  DIVORCE
  FUNERAL
  FAMILY
  RESIDENCE
  PREGNANCY
  EDUCATION
  MILITARY
  CUSTOM
}

enum SacramentType {
  BAPTISM
  INFANT_BAPTISM
  CONFIRMATION
  COMMUNION
  MEMBERSHIP_TRANSFER
  CUSTOM
}

enum ChatSpeakerRole {
  PASTOR
  ASSISTANT
  SYSTEM
}

enum ExtractedUpdateType {
  MEMBER_PROFILE
  HOUSEHOLD_PROFILE
  RELATIONSHIP
  PRAYER
  CARE_RECORD
  ATTENDANCE
  CHURCH_EVENT
  FOLLOW_UP
  STATUS_CHANGE
}

enum ExtractedUpdateStatus {
  DRAFT
  NEEDS_REVIEW
  CONFIRMED
  REJECTED
  MERGED
}

enum ReviewReason {
  AMBIGUOUS_MEMBER_MATCH
  AMBIGUOUS_HOUSEHOLD_MATCH
  RELATIONSHIP_UNCERTAIN
  DUPLICATE_CANDIDATE
  LOW_CONFIDENCE
  MISSING_REQUIRED_FIELD
  CONFLICTING_EXISTING_DATA
}

enum ReviewItemStatus {
  PENDING
  APPROVED
  EDITED_AND_APPROVED
  REJECTED
  SKIPPED
  MERGED
}

model Church {
  id                      String                  @id @default(cuid())
  slug                    String                  @unique
  name                    String
  timezone                String                  @default("Asia/Seoul")
  isActive                Boolean                 @default(true)
  adminNote               String?
  priorityTag             String?
  memberships             ChurchMembership[]
  subscriptions           Subscription[]
  roles                   Role[]
  households              Household[]
  districts               District[]
  groups                  Group[]
  members                 Member[]
  organizationUnits       OrganizationUnit[]
  organizationUnitLabels  OrganizationUnitLabel[]
  memberOrganizationLinks MemberOrganization[]
  memberRelationships     MemberRelationship[]    @relation("RelationshipChurch")
  careRecords             MemberCareRecord[]
  lifeStatuses            MemberLifeStatus[]
  faithMilestones         MemberFaithMilestone[]
  applicationForms        ApplicationForm[]
  applications            Application[]
  notices                 Notice[]
  blogPosts               BlogPost[]
  activityLogs            ActivityLog[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  name         String
  isActive     Boolean            @default(true)
  memberships  ChurchMembership[]
  activityLogs ActivityLog[]
  notices      Notice[]           @relation("NoticeAuthor")
  guidePosts   GuidePost[]        @relation("GuidePostAuthor")
  blogPosts    BlogPost[]         @relation("BlogPostAuthor")
  applications Application[]      @relation("ApplicationAssignee")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model ChurchMembership {
  id         String         @id @default(cuid())
  userId     String
  churchId   String
  role       MembershipRole @default(VIEWER)
  roleId     String?
  isActive   Boolean        @default(true)
  joinedAt   DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id])
  church     Church         @relation(fields: [churchId], references: [id])
  customRole Role?          @relation(fields: [roleId], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, churchId])
  @@index([churchId, role])
}

model Role {
  id          String             @id @default(cuid())
  churchId    String?
  key         String
  name        String
  church      Church?            @relation(fields: [churchId], references: [id])
  memberships ChurchMembership[]
  createdAt   DateTime           @default(now())

  @@unique([churchId, key])
  @@index([churchId])
}

model Subscription {
  id               String             @id @default(cuid())
  churchId         String
  plan             Plan               @default(FREE)
  status           SubscriptionStatus @default(TRIALING)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  church           Church             @relation(fields: [churchId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([churchId, status])
}

model Household {
  id        String   @id @default(cuid())
  churchId  String?
  name      String
  address   String?
  notes     String?
  church    Church?  @relation(fields: [churchId], references: [id])
  members   Member[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId, name])
}

model District {
  id        String   @id @default(cuid())
  churchId  String?
  name      String
  leadName  String?
  church    Church?  @relation(fields: [churchId], references: [id])
  groups    Group[]
  members   Member[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([churchId, name])
  @@index([churchId])
}

model Group {
  id         String    @id @default(cuid())
  churchId   String?
  name       String
  districtId String
  church     Church?   @relation(fields: [churchId], references: [id])
  district   District  @relation(fields: [districtId], references: [id])
  members    Member[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([churchId, districtId, name])
  @@index([churchId])
}

model Member {
  id                    String                 @id @default(cuid())
  churchId              String?
  name                  String
  gender                Gender
  birthDate             DateTime
  phone                 String
  email                 String?
  address               String?
  householdId           String?
  districtId            String?
  groupId               String?
  currentJob            String?
  previousChurch        String?
  previousFaith         String?
  baptismStatus         String?
  church                Church?                @relation(fields: [churchId], references: [id])
  household             Household?             @relation(fields: [householdId], references: [id])
  district              District?              @relation(fields: [districtId], references: [id])
  group                 Group?                 @relation(fields: [groupId], references: [id])
  organizations         MemberOrganization[]
  relationshipsFrom     MemberRelationship[]   @relation("MemberRelationshipFrom")
  relationshipsTo       MemberRelationship[]   @relation("MemberRelationshipTo")
  careRecords           MemberCareRecord[]
  lifeStatuses          MemberLifeStatus[]
  faithMilestones       MemberFaithMilestone[]
  registeredAt          DateTime               @default(now())
  position              String?
  statusTag             String
  requiresFollowUp      Boolean                @default(false)
  notes                 String?
  isDeleted             Boolean                @default(false)
  activityLogs          ActivityLog[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([churchId, statusTag])
  @@index([churchId, requiresFollowUp])
  @@index([churchId, registeredAt])
}

model ApplicationForm {
  id           String        @id @default(cuid())
  churchId     String?
  title        String
  description  String?
  isActive     Boolean       @default(true)
  church       Church?       @relation(fields: [churchId], references: [id])
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([churchId, isActive])
}

model Application {
  id             String            @id @default(cuid())
  churchId       String?
  formId         String
  form           ApplicationForm   @relation(fields: [formId], references: [id])
  applicantName  String
  applicantPhone String?
  payloadJson    String?
  status         ApplicationStatus @default(PENDING)
  assignedToId   String?
  assignedTo     User?             @relation("ApplicationAssignee", fields: [assignedToId], references: [id])
  church         Church?           @relation(fields: [churchId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([churchId, status])
  @@index([churchId, createdAt])
}

model Notice {
  id        String   @id @default(cuid())
  churchId  String?
  title     String
  content   String
  pinned    Boolean  @default(false)
  authorId  String
  author    User     @relation("NoticeAuthor", fields: [authorId], references: [id])
  church    Church?  @relation(fields: [churchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([churchId, createdAt])
}

model GuidePost {
  id            String           @id @default(cuid())
  title         String
  slug          String           @unique
  excerpt       String?
  seoTitle      String?
  seoDescription String?
  content       String
  coverImageUrl String?
  published     Boolean          @default(false)
  publishedAt   DateTime?
  authorId      String
  author        User             @relation("GuidePostAuthor", fields: [authorId], references: [id])
  images        GuidePostImage[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([published, publishedAt])
  @@index([createdAt])
}

model GuidePostImage {
  id        String    @id @default(cuid())
  postId     String
  post       GuidePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  imageUrl   String
  alt        String?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([postId, sortOrder])
}

model BlogPost {
  id            String         @id @default(cuid())
  churchId       String
  authorId       String
  title          String
  slug           String
  excerpt        String?
  seoTitle       String?
  seoDescription String?
  contentJson    String
  coverImageUrl  String?
  status         BlogPostStatus @default(DRAFT)
  publishedAt    DateTime?
  church         Church         @relation(fields: [churchId], references: [id])
  author         User           @relation("BlogPostAuthor", fields: [authorId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([churchId, slug])
  @@index([churchId, status])
  @@index([churchId, createdAt])
}

model OrganizationUnit {
  id             String                 @id @default(cuid())
  churchId       String
  name           String
  slug           String
  type           OrganizationUnitType
  parentId       String?
  parent         OrganizationUnit?      @relation("OrganizationTree", fields: [parentId], references: [id])
  children       OrganizationUnit[]     @relation("OrganizationTree")
  church         Church                 @relation(fields: [churchId], references: [id])
  memberLinks    MemberOrganization[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([churchId, slug])
  @@index([churchId, type])
  @@index([parentId])
}

model OrganizationUnitLabel {
  id        String               @id @default(cuid())
  churchId   String
  type      OrganizationUnitType
  singular  String
  plural    String?
  church    Church               @relation(fields: [churchId], references: [id])
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([churchId, type])
}

model MemberOrganization {
  id              String           @id @default(cuid())
  churchId        String
  memberId        String
  organizationId  String
  role            MemberOrgRole    @default(MEMBER)
  customRoleLabel String?
  isPrimary       Boolean          @default(false)
  startedAt       DateTime?
  endedAt         DateTime?
  notes           String?
  church          Church           @relation(fields: [churchId], references: [id])
  member          Member           @relation(fields: [memberId], references: [id])
  organization    OrganizationUnit @relation(fields: [organizationId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([churchId, memberId])
  @@index([churchId, organizationId])
  @@index([churchId, role])
}

model MemberRelationship {
  id                   String           @id @default(cuid())
  churchId             String
  fromMemberId         String
  toMemberId           String
  relationshipType     RelationshipType
  customRelationship   String?
  isPrimaryFamilyLink  Boolean          @default(false)
  notes                String?
  church               Church           @relation("RelationshipChurch", fields: [churchId], references: [id])
  fromMember           Member           @relation("MemberRelationshipFrom", fields: [fromMemberId], references: [id])
  toMember             Member           @relation("MemberRelationshipTo", fields: [toMemberId], references: [id])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([churchId, fromMemberId])
  @@index([churchId, toMemberId])
  @@unique([fromMemberId, toMemberId, relationshipType])
}

model MemberCareRecord {
  id            String        @id @default(cuid())
  churchId      String
  memberId      String
  category      CareCategory
  customCategory String?
  title         String
  summary       String?
  details       String?
  happenedAt    DateTime      @default(now())
  recordedBy    String?
  church        Church        @relation(fields: [churchId], references: [id])
  member        Member        @relation(fields: [memberId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([churchId, memberId, happenedAt])
  @@index([churchId, category])
}

model MemberLifeStatus {
  id          String         @id @default(cuid())
  churchId     String
  memberId     String
  type        LifeStatusType
  customType  String?
  title       String
  status      String?
  summary     String?
  details     String?
  happenedAt  DateTime?
  isActive    Boolean        @default(true)
  church      Church         @relation(fields: [churchId], references: [id])
  member      Member         @relation(fields: [memberId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([churchId, memberId])
  @@index([churchId, type])
}

model MemberFaithMilestone {
  id              String         @id @default(cuid())
  churchId        String
  memberId        String
  type            SacramentType
  customType      String?
  happenedAt      DateTime?
  churchName      String?
  officiant       String?
  notes           String?
  church          Church         @relation(fields: [churchId], references: [id])
  member          Member         @relation(fields: [memberId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([churchId, memberId])
  @@index([churchId, type])
}

model ActivityLog {
  id         String   @id @default(cuid())
  churchId   String?
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String?
  memberId   String?
  member     Member?  @relation(fields: [memberId], references: [id])
  metadata   String?
  church     Church?  @relation(fields: [churchId], references: [id])
  createdAt  DateTime @default(now())

  @@index([churchId, createdAt])
}

model ChatCapture {
  id               String            @id @default(cuid())
  churchId         String
  speakerRole      ChatSpeakerRole
  sourceChannel    String            @default("WEB_CHAT")
  sourceChatId     String?
  sourceMessageId  String?
  rawText          String
  threadKey        String            @default("main")
  happenedAt       DateTime          @default(now())
  capturedAt       DateTime          @default(now())
  extractedUpdates ExtractedUpdate[]

  @@index([churchId, threadKey, capturedAt])
}

model ExtractedUpdate {
  id                  String                @id @default(cuid())
  churchId            String
  captureId           String
  updateType          ExtractedUpdateType
  confidence          Float                 @default(0)
  payloadJson         Json
  targetMemberHint    String?
  targetHouseholdHint String?
  ambiguityFlags      Json?
  sourceSummary       String?
  suggestedAction     String?
  reviewPrompt        String?
  status              ExtractedUpdateStatus @default(DRAFT)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  capture             ChatCapture           @relation(fields: [captureId], references: [id], onDelete: Cascade)
  reviewItems         ReviewItem[]
  applyResults        ApplyResult[]

  @@index([churchId, status, createdAt])
  @@index([captureId])
  @@index([churchId, updateType])
}

model ReviewItem {
  id                String           @id @default(cuid())
  churchId          String
  extractedUpdateId String
  reviewReason      ReviewReason
  title             String
  summary           String
  suggestedAction   String
  status            ReviewItemStatus @default(PENDING)
  reviewerId        String?
  reviewedAt        DateTime?
  resolutionNote    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  extractedUpdate   ExtractedUpdate  @relation(fields: [extractedUpdateId], references: [id], onDelete: Cascade)

  @@index([churchId, status, createdAt])
  @@index([extractedUpdateId])
}

model ApplyResult {
  id                String          @id @default(cuid())
  extractedUpdateId String
  appliedEntityType String?
  appliedEntityId   String?
  appliedPatchJson  Json?
  actorId           String?
  appliedAt         DateTime        @default(now())
  extractedUpdate   ExtractedUpdate @relation(fields: [extractedUpdateId], references: [id], onDelete: Cascade)

  @@index([extractedUpdateId, appliedAt])
}
