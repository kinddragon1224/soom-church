{
  "name": "soom-church-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Soom Church microservice workspace",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose.yml up --build",
    "dev:detach": "docker compose -f docker-compose.yml up --build -d",
    "down": "docker compose -f docker-compose.yml down",
    "logs": "docker compose -f docker-compose.yml logs -f",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.3"
  }
}
