{
  "name": "soom-church",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:visual-mvp": "tsx scripts/seed-visual-mvp.ts",
    "mobile:install": "npm --prefix apps/mobile-app install --legacy-peer-deps",
    "mobile:dev": "npm --prefix apps/mobile-app run dev",
    "mobile:dev:clear": "npm --prefix apps/mobile-app run dev:clear",
    "mobile:dev:tunnel": "npm --prefix apps/mobile-app run dev:tunnel",
    "mobile:dev:recover": "bash scripts/mobile-dev-recover.sh",
    "mobile:typecheck": "npm --prefix apps/mobile-app run typecheck",
    "mobile:view": "bash scripts/mobile-view.sh",
    "chat:doctor": "node scripts/chat-bridge-doctor.mjs",
    "threads:plan": "node scripts/threads-generate-day-plan.mjs",
    "threads:post": "node scripts/threads-publish-slot.mjs",
    "threads:report": "node scripts/threads-daily-insights.mjs",
    "threads:backfill-comments": "node scripts/threads-backfill-comments.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.30",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-force-graph": "^1.48.2",
    "tailwind-merge": "^3.0.2",
    "three": "^0.183.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "prisma": "^6.4.1",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.19.3",
    "typescript": "^5.5.3"
  }
}
